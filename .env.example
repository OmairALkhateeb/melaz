# =============================================================================
# AL MELAZ MOTORS — Frontend environment variables
# Copy to `.env` for local development. Restart `npm run dev` after changes.
# =============================================================================

# Laravel API base URL (no trailing slash)
VITE_API_BASE_URL=http://melaz-motors.livetech.it.com

# Local example:
# VITE_API_BASE_URL=http://localhost:8000

# Public website URL (used for WhatsApp message links; optional locally)
# VITE_SITE_URL=http://localhost:5173

# Production example:
# VITE_SITE_URL=https://almelazmotors.com

# Default business WhatsApp number when a car has no whatsapp_number
# International format — digits only or with + / spaces
VITE_WHATSAPP_NUMBER=963941996885
