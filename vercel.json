{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://melaz-motors.livetech.it.com/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "http://melaz-motors.livetech.it.com/storage/:path*"
    },
    { "source": "/(.*)", "destination": "/_shell.html" }
  ]
}
